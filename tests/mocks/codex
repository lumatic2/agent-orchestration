#!/usr/bin/env bash
# Mock codex CLI for testing
# Control behavior via MOCK_CODEX_BEHAVIOR env var

BEHAVIOR="${MOCK_CODEX_BEHAVIOR:-success}"

case "$BEHAVIOR" in
  success)
    echo '{"type":"agent_message","text":"Task completed successfully. All files updated."}'
    echo '{"type":"turn.completed","usage":{"input_tokens":500,"output_tokens":200}}'
    exit 0
    ;;
  rate_limit)
    echo "Error: 429 rate limit exceeded. Please retry later."
    exit 1
    ;;
  error)
    echo "Error: Internal server error"
    exit 1
    ;;
  empty)
    echo ""
    exit 0
    ;;
  *)
    echo "Unknown mock behavior: $BEHAVIOR"
    exit 1
    ;;
esac
